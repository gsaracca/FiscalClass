FiscalErrors.AddError procedure( string _error_id, string _error_desc )!,private
    code
    clear( self.Qerrors )
    self.Qerrors.error_id = clip(_error_id)
    self.Qerrors.error_desc = clip(_error_desc)
    add( self.Qerrors )

FiscalErrors.GetErrorDesc procedure( string _error_id )!,string
rta         cstring(256)
    code
    rta = 'Error Desconocido/No Encontrado'
    clear( self.Qerrors )
    self.Qerrors.error_id = clip(_error_id)
    get( self.Qerrors, self.Qerrors.error_id )
    if not errorcode()
        rta = self.Qerrors.error_desc
    end !* if *

    return rta

FiscalErrors.Clean procedure()
    code
    clear( self.Qerrors )
    free( self.Qerrors )

